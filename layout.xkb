xkb_keymap {
	xkb_keycodes  { include "evdev+aliases(qwerty)"	};
	xkb_types     { include "complete"	};
	xkb_compat    { include "complete"	};
	xkb_symbols   { include "pc+us+ru(ruu):2+inet(evdev)+compose(rwin-altgr)+group(shift_caps_toggle)+level3(ralt_switch)+nbsp(level3)"	};
	xkb_geometry  { include "pc(pc105)"	};
};
