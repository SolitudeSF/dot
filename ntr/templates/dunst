[global]
follow = mouse
width = (0, 400)
height = (0, 200)
origin = top-right
offset = (5, 34)
separator_height = 2
padding = 8
horizontal_padding = 8
text_icon_padding = 0
frame_width = 2
frame_color = "<{color.fg}>"
separator_color = frame
sort = yes
idle_threshold = 120

font = sans 11
markup = full
format = "<b>%s</b>\n%b\n%p"
show_age_threshold = 60
word_wrap = yes

icon_position = left
min_icon_size = 32
max_icon_size = 64
icon_theme = Vimix-ruby-dark
enable_recursive_icon_lookup = true

history_length = 50

dmenu = /usr/bin/vicinae dmenu

mouse_left_click = do_action
mouse_middle_click = close_all
mouse_right_click = close_current

[urgency_low]
background = "<{color.bg}>dd"
foreground = "<{color.fg}>"
timeout = 10

[urgency_normal]
background = "<{color.bg}>dd"
foreground = "<{color.fg}>"
timeout = 10

[urgency_critical]
background = "<{color.bg}>dd"
foreground = "<{color.fg}>"
frame_color = "<{color.fg}>"
timeout = 0

[history-ignore]
appname = "kitty"
history_ignore = yes
