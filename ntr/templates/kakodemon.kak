set-option -add global ui_options \
'kakodemon_color_black=rgb:<{strip:<{color0}>:#}>' \
'kakodemon_color_red=rgb:<{strip:<{color1}>:#}>' \
'kakodemon_color_green=rgb:<{strip:<{color2}>:#}>' \
